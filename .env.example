# Database connection string for PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/task_api

# JWT secret for token signing (minimum 64 characters required)
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-64-characters-long-for-security

# Server port (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# Allowed CORS origins (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173